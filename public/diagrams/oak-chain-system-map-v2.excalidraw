    {
      "id": "v2-concern-box-text",
      "type": "text",
      "x": 70,
      "y": 942,
      "width": 1080,
      "height": 95,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1006,
      "version": 1,
      "versionNonce": 1006,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Separation of Concerns\nExperience Surface: EDS apps, SDK clients, connector adapters\nConsensus Truth Plane: proposal ordering, replication, segment durability, gc safety\nSettlement & Addressing Plane: Ethereum contract verification + IPFS content addressing\nObservability Plane: /v1/queue, /v1/consensus, /v1/gc, events stream consumed by ops tools",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 14,
      "containerId": "v2-concern-box",
      "originalText": "Separation of Concerns\nExperience Surface: EDS apps, SDK clients, connector adapters\nConsensus Truth Plane: proposal ordering, replication, segment durability, gc safety\nSettlement & Addressing Plane: Ethereum contract verification + IPFS content addressing\nObservability Plane: /v1/queue, /v1/consensus, /v1/gc, events stream consumed by ops tools",
      "lineHeight": 1.25
    },
