    {
      "id": "v2-contract-box-text",
      "type": "text",
      "x": 610,
      "y": 736,
      "width": 540,
      "height": 142,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1004,
      "version": 1,
      "versionNonce": 1004,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Smart Contracts (expanded)\n- Payment verification and gating\n- Durability/finality policy hooks\n- Settlement evidence backing queue transitions\n- Economic security boundary outside validator runtime\n- Contract outcomes surface into validator policy + ops telemetry",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 14,
      "containerId": "v2-contract-box",
      "originalText": "Smart Contracts (expanded)\n- Payment verification and gating\n- Durability/finality policy hooks\n- Settlement evidence backing queue transitions\n- Economic security boundary outside validator runtime\n- Contract outcomes surface into validator policy + ops telemetry",
      "lineHeight": 1.25
    },
    {
